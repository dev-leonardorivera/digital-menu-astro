<!-- Añadimos 'hidden' por defecto para evitar que parpadee al cargar si ya se aceptaron -->
<div
  id="cookie-banner"
  class="hidden fixed bottom-6 left-6 right-6 md:left-auto md:max-w-md bg-[var(--color-primary-dark)] border border-white/10 p-6 rounded-2xl shadow-2xl z-[100] transform translate-y-20 opacity-0 transition-all duration-500"
>
  <div class="flex flex-col gap-4">
    <div class="flex items-start gap-4">
      <div class="p-2 bg-[var(--color-primary-light)]/10 rounded-lg">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-[var(--color-primary-light)]"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"
          ></path><path d="M8.5 8.5v.01"></path><path d="M16 15.5v.01"
          ></path><path d="M12 12v.01"></path><path d="M11 17v.01"></path><path
            d="M7 14v.01"></path></svg
        >
      </div>
      <div>
        <h3 class="text-white font-bold text-sm">¿Un café y una cookie?</h3>
        <p class="text-[var(--color-surface)]/60 text-xs mt-1 leading-relaxed">
          Usamos cookies para mejorar tu experiencia y analizar el tráfico.
          Consulta nuestra <a
            href="cookies"
            class="text-[var(--color-primary-light)] underline"
            >política de cookies</a
          >.
        </p>
      </div>
    </div>

    <div class="flex gap-3 mt-2">
      <button
        id="accept-cookies"
        class="flex-1 bg-[var(--color-primary-light)] hover:bg-white text-[var(--color-primary-dark)] text-[10px] font-bold uppercase py-3 rounded-xl transition-all"
      >
        Aceptar todas
      </button>
      <button
        id="deny-cookies"
        class="flex-1 bg-white/5 hover:bg-white/10 text-white text-[10px] font-bold uppercase py-3 rounded-xl transition-all border border-white/10"
      >
        Rechazar
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById("cookie-banner");
  const acceptBtn = document.getElementById("accept-cookies");
  const denyBtn = document.getElementById("deny-cookies");

  // Función para cerrar el banner con animación y luego ocultarlo
  const closeBanner = () => {
    if (!banner) return;

    // 1. Añadimos clases de animación y quitamos interacción
    banner.classList.add("translate-y-20", "opacity-0", "pointer-events-none");

    // 2. Esperamos a que termine la animación (500ms) para poner display: none
    setTimeout(() => {
      banner.classList.add("hidden");
    }, 500);
  };

  // 1. Mostrar banner si no hay respuesta previa
  const consent = localStorage.getItem("cookies-accepted");
  if (consent === null) {
    // Quitamos 'hidden' primero para que pueda animarse
    banner?.classList.remove("hidden");

    setTimeout(() => {
      banner?.classList.remove("translate-y-20", "opacity-0");
    }, 100); // Un pequeño delay para que el navegador registre que ya no es 'hidden'
  }

  // 2. Lógica de botones
  acceptBtn?.addEventListener("click", () => {
    localStorage.setItem("cookies-accepted", "true");
    window.dispatchEvent(new Event("storage"));
    closeBanner();
  });

  denyBtn?.addEventListener("click", () => {
    localStorage.setItem("cookies-accepted", "false");
    closeBanner();
  });

  // 3. Escuchar desde fuera
  window.addEventListener("storage", () => {
    if (localStorage.getItem("cookies-accepted") !== null) {
      closeBanner();
    }
  });
</script>
