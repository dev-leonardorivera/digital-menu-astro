---
import { Image } from "astro:assets";

interface Props {
  name: string;
  price: string;
  description: string;
  image: any; // o ImageMetadata
  tag?: string;
  notes: string[];
  intensity: number;
  category: string;
}

const { name, price, description, image, tag, notes, intensity, category } =
  Astro.props;
---

<div
  class="group bg-[var(--color-bg)] rounded-[2.5rem] overflow-hidden border border-[var(--color-primary-light)]/20 hover:shadow-2xl transition-all duration-700 flex flex-col h-full"
>
  <!-- Imagen con Zoom Suave -->
  <div class="relative h-64 overflow-hidden">
    <Image
      src={image}
      alt={name}
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
    />
    <div class="absolute top-5 left-5">
      <span
        class="bg-[var(--color-surface)]/80 backdrop-blur-md text-[var(--color-primary-dark)] text-[10px] font-bold px-4 py-1.5 rounded-full uppercase tracking-tighter"
      >
        {tag}
      </span>
    </div>
  </div>

  <div class="p-8 flex flex-col flex-grow">
    <!-- Título y Precio -->
    <div class="flex justify-between items-start mb-4">
      <h3 class="text-2xl font-bold text-[var(--color-text)] tracking-tight">
        {name}
      </h3>
      <!-- Precio moderno: sin itálica, más grueso y limpio -->
      <span class="text-xl font-bold text-[var(--color-accent)] mt-1">
        {price}
      </span>
    </div>

    <!-- Notas de Sabor (Visuales) -->
    <!-- Reducido el margen inferior de mb-6 a mb-4 para compactar -->
    <div class="flex flex-wrap gap-2 mb-4">
      {
        notes.map((note) => (
          <span class="text-[11px] font-medium text-[var(--color-text)]/70 border border-[var(--color-text)]/10 px-3 py-1 rounded-full">
            {note}
          </span>
        ))
      }
    </div>

    <!-- Descripción -->
    <!-- Cambiado text-sm a text-base, aumentada la opacidad a /80, eliminado italic/comillas y reducido mb-8 a mb-6 -->
    <p class="text-[var(--color-text)]/80 text-base leading-relaxed">
      {description}
    </p>

    <!-- Perfil del Barista -->
    <div class="mt-auto pt-5 border-t border-[var(--color-primary-light)]/20">
      <div class="flex items-center justify-between">
        <div class="flex flex-col gap-1.5">
          <span
            class="text-[10px] uppercase tracking-widest text-[var(--color-text)]/50 font-bold"
            >Intensidad</span
          >
          <div class="flex gap-1">
            {
              [...Array(5)].map((_, i) => (
                <div
                  class={`w-2 h-2 rounded-full ${i < intensity ? "bg-[var(--color-accent)]" : "bg-[var(--color-text)]/15"}`}
                />
              ))
            }
          </div>
        </div>

        <!-- <a
          href="#detalles"
          class="text-[var(--color-primary)] text-sm font-bold flex items-center gap-2 group/link"
        >
          <span class="relative overflow-hidden inline-block">
            <span
              class="inline-block transition-transform duration-300 group-hover/link:-translate-y-full"
              >Explorar matices</span
            >
            <span
              class="absolute top-0 left-0 inline-block transition-transform duration-300 translate-y-full group-hover/link:translate-y-0"
              >Saber más</span
            >
          </span>
          <i
            class="fa-solid fa-arrow-right text-xs transition-transform duration-300 group-hover/link:translate-x-1"
          ></i>
        </a> -->
      </div>
    </div>
  </div>
</div>
