---
const year = new Date().getFullYear();
import { Icon } from "astro-icon/components";
---

<footer class="bg-[var(--color-primary-dark)] text-[var(--color-surface)] pt-20 pb-10 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand -->
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-2xl font-bold mb-6">
          Café<span class="text-[var(--color-primary-light)]">Artesano</span>
        </h3>
        <p class="text-[var(--color-surface)]/60 text-sm leading-relaxed">
          Tostando sueños y sirviendo comunidad desde 1992. El mejor café de
          especialidad en el corazón de tu ciudad.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-[0.2em] text-[var(--color-primary-light)] opacity-80">
          Navegación
        </h4>
        <ul class="space-y-4 text-sm text-[var(--color-surface)]/80">
          <li><a href="/" class="hover:text-[var(--color-primary-light)] transition-colors">Inicio</a></li>
          <li><a href="/menu" class="hover:text-[var(--color-primary-light)] transition-colors">Nuestro Menú</a></li>
          <li><a href="/nosotros" class="hover:text-[var(--color-primary-light)] transition-colors">Sobre Nosotros</a></li>
          <li><a href="/contacto" class="hover:text-[var(--color-primary-light)] transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-[0.2em] text-[var(--color-primary-light)] opacity-80">
          Síguenos
        </h4>
        <div class="flex gap-4">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" class="group w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--color-primary-light)] transition-all duration-300">
             <Icon name="mdi:facebook" class="w-6 h-6 text-white group-hover:text-[var(--color-primary-dark)]" />
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="group w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-[var(--color-primary-light)] transition-all duration-300">
             <Icon name="mdi:instagram" class="w-6 h-6 text-white group-hover:text-[var(--color-primary-dark)]" />
          </a>
        </div>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="font-bold mb-6 uppercase text-xs tracking-[0.2em] text-[var(--color-primary-light)] opacity-80">
          Únete al club
        </h4>
        <p class="text-xs text-[var(--color-surface)]/60 mb-4">
          Recibe recetas y ofertas exclusivas.
        </p>
        <form class="flex flex-col gap-3">
          <div class="flex gap-2">
            <input
              type="email"
              placeholder="Email"
              required
              class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm w-full focus:outline-none focus:border-[var(--color-primary-light)] text-white"
            />
            <button
              type="submit"
              aria-label="Enviar"
              class="bg-[var(--color-primary-light)] text-[var(--color-primary-dark)] px-4 h-10 rounded-lg font-bold hover:bg-white transition-colors flex items-center justify-center group shrink-0"
            >
              <Icon name="mdi:send" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" />
            </button>
          </div>
          
          <!-- CHECKBOX LEGAL - AQUÍ ESTABA EL ERROR (Cerrado correctamente ahora) -->
          <label class="flex items-start gap-2 cursor-pointer">
            <input type="checkbox" required class="mt-1 accent-[var(--color-primary-light)]" />
            <span class="text-[10px] text-[var(--color-surface)]/50 leading-tight">
              Acepto la <a href="/legal/privacidad" class="underline hover:text-white">política de privacidad</a>.
            </span>
          </label>
        </form>
      </div>
    </div>

    <!-- Footer Bottom: Legal & Copyright -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-6 text-[var(--color-surface)]/40 text-[10px] uppercase tracking-widest font-medium">
      <p>&copy; {year} Café Artesano España. Todos los derechos reservados.</p>
      
      <nav class="flex flex-wrap justify-center gap-6">
        <a href="/legal/aviso-legal" class="hover:text-[var(--color-primary-light)] transition-colors">Aviso Legal</a>
        <a href="/legal/privacidad" class="hover:text-[var(--color-primary-light)] transition-colors">Privacidad</a>
        <a href="/legal/cookies" class="hover:text-[var(--color-primary-light)] transition-colors">Cookies</a>
      </nav>
    </div>
  </div>
</footer>