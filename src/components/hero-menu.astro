---
import { Image } from "astro:assets";
// Importa tu imagen si la tienes en src/assets
// import bgImage from '../assets/menu-hero-bg.jpg';
---

<header
  class="pt-32 pb-24 px-6 text-center mx-auto bg-[var(--color-primary-dark)]"
>
  <span
    class="text-[var(--color-primary)] font-bold uppercase text-xs tracking-[0.4em] mt-5 mb-4 block"
  >
    Selección Artesanal
  </span>
  <h1
    class="text-6xl md:text-8xl font-bold text-[var(--color-surface)] tracking-tighter mb-4"
  >
    La Carta<span class="text-[var(--color-surface)]">.</span>
  </h1>
  <p class="text-[var(--color-surface)]/60 max-w-xl mx-auto text-lg italic">
    "Momentos especiales a través de una colección de sabores destacados por
    nuestros baristas."
  </p>
</header>
