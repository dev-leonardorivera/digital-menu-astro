---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <!-- Forzamos el fondo oscuro para que combine con el Header y Footer -->
  <div class="bg-[var(--color-primary-dark)] min-h-screen">
    <section class="pt-32 pb-20 px-4 max-w-3xl mx-auto">
      <!-- Cabecera de la página -->
      <div class="mb-12 border-b border-white/10 pb-8 text-left">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-px bg-[var(--color-highlight)]"></div>
          <span
            class="text-[var(--color-highlight)] uppercase text-[10px] tracking-[0.3em] font-bold"
            >Información</span
          >
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tighter">
          Aviso <span class="text-[var(--color-primary-light)]">Legal</span>
        </h1>
      </div>

      <!-- Contenido del Aviso Legal -->
      <div
        class="space-y-10 text-[var(--color-surface)]/70 text-sm leading-relaxed"
      >
        <section>
          <h2 class="text-white font-bold text-lg mb-4 flex items-center gap-2">
            1. Datos del Titular
          </h2>
          <div
            class="bg-white/5 border border-white/10 p-6 rounded-2xl space-y-2"
          >
            <p>
              <strong class="text-white">Razón Social:</strong> Café Artesano S.L.
            </p>
            <p><strong class="text-white">NIF:</strong> B-12345678</p>
            <p>
              <strong class="text-white">Domicilio:</strong> Calle de la Torrefacción,
              45, 28001 Madrid.
            </p>
            <p>
              <strong class="text-white">Registro:</strong> Inscrita en el Registro
              Mercantil de Madrid, Tomo 123, Folio 45, Hoja M-6789.
            </p>
          </div>
        </section>

        <section>
          <h2 class="text-white font-bold text-lg mb-4">
            2. Propiedad Intelectual
          </h2>
          <p>
            Todos los contenidos de este sitio web, incluyendo textos, imágenes,
            logotipos y el diseño de la interfaz, son propiedad de <span
              class="text-[var(--color-primary-light)]">Café Artesano</span
            > o de sus licenciantes y están protegidos por las leyes de propiedad
            intelectual e industrial.
          </p>
        </section>

        <section>
          <h2 class="text-white font-bold text-lg mb-4">3. Responsabilidad</h2>
          <p>
            No nos hacemos responsables de los daños y perjuicios derivados del
            uso de este sitio web, ni de los contenidos de enlaces externos que
            puedan aparecer. El usuario se compromete a hacer un uso lícito de
            la web.
          </p>
        </section>

        <section>
          <h2 class="text-white font-bold text-lg mb-4">
            4. Legislación Aplicable
          </h2>
          <p>
            Para la resolución de todas las controversias o cuestiones
            relacionadas con el presente sitio web será de aplicación la <span
              class="text-white">legislación española</span
            >, a la que se someten expresamente las partes.
          </p>
        </section>
      </div>

      <!-- Botón volver -->
      <div class="mt-16">
        <a
          href="/digital-menu-astro/"
          class="inline-flex items-center gap-2 text-[var(--color-primary-light)] hover:text-white transition-colors text-xs font-bold uppercase tracking-widest group"
        >
          <Icon
            name="send"
            class="w-4 h-4 rotate-180 transition-transform group-hover:-translate-x-1"
          />
          Volver a la cafetería
        </a>
      </div>
    </section>
  </div>
</Layout>
