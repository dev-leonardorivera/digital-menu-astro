---
import Layout from "../layouts/Layout.astro"; // Usamos tu layout para el Header/Footer
import { Icon } from "astro-icon/components";
---

<Layout>
  <!-- Envolvemos todo en un div que fuerce el fondo oscuro -->
  <div class="bg-[var(--color-primary-dark)] min-h-screen">
    <section class="pt-32 pb-20 px-4 max-w-3xl mx-auto">
      <div class="mb-12 border-b border-white/10 pb-8 text-left">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-px bg-[var(--color-primary-light)]"></div>
          <span
            class="text-[var(--color-accent)] uppercase text-[10px] tracking-[0.3em] font-bold"
            >Legal</span
          >
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tighter">
          Política de <span class="text-[var(--color-primary-light)]"
            >Privacidad</span
          >
        </h1>
      </div>

      <div
        class="space-y-10 text-[var(--color-surface)]/80 leading-relaxed text-sm"
      >
        <section>
          <h2 class="text-white font-bold text-lg mb-4">
            Responsable del tratamiento
          </h2>
          <div class="bg-white/5 border border-white/10 p-6 rounded-2xl">
            <p>
              <strong class="text-white">Titular:</strong> Café Artesano S.L.
            </p>
            <p>
              <strong class="text-white">Email:</strong> contacto@cafeartesano.es
            </p>
          </div>
        </section>

        <section>
          <h2 class="text-white font-bold text-lg mb-4">Finalidad</h2>
          <p>
            Gestionar tus consultas y enviarte novedades sobre nuestro café de
            especialidad.
          </p>
        </section>
      </div>

      <div class="mt-16">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-[var(--color-primary-light)] hover:text-white transition-colors text-xs font-bold uppercase tracking-widest group"
        >
          <Icon
            name="send"
            class="w-4 h-4 rotate-180 transition-transform group-hover:-translate-x-1"
          />
          Volver al inicio
        </a>
      </div>
    </section>
  </div>
</Layout>
