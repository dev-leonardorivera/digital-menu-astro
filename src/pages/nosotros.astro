---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import PhotoGrid from "../components/PhotoGrid.astro";
import { Image } from "astro:assets";

// Importación manual de imágenes (Astro necesita esto para optimizarlas)
import imgStore from "../assets/img/img-store.jpg";
import coffee1 from "../assets/img/img-Cold-Brew-Vainilla.jpg";
import food1 from "../assets/img/img-Caramel-Macchiato.webp";
import coffee2 from "../assets/img/img-Flat-Especial.jpg";
import food2 from "../assets/img/img-Filtrado-V60.jpg";

const gallery = [
  { src: coffee1, alt: "Café de especialidad" },
  { src: food1, alt: "Tostada artesanal" },
  { src: coffee2, alt: "Latte art" },
  { src: food2, alt: "Repostería casera" },
];
---

<!-- Cambiamos el fondo a var(--color-surface) y el texto base a dark -->
<Layout title="Sobre Nosotros | Café Artesano">
  <main
    class="bg-[var(--color-surface)] pt-32 pb-20 text-[var(--color-primary-dark)]"
  >
    <!-- Bloque Principal: Historia -->
    <section
      class="px-6 py-20 max-w-7xl mx-auto border-b border-[var(--color-primary-dark)]/5"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start py-5">
        <!-- Foto del equipo con componente Image -->
        <div
          class="aspect-square md:aspect-square overflow-hidden rounded-[2.5rem] bg-[var(--color-primary-dark)]/5 shadow-sm"
        >
          <Image
            src={imgStore}
            alt="Nuestro equipo en el local"
            class="w-full h-full object-cover"
            quality="high"
          />
        </div>

        <!-- Contenido Editorial -->
        <div class="lg:sticky lg:top-32">
          <!-- El color primario suele resaltar más sobre fondo claro -->
          <span
            class="text-[var(--color-primary)] font-bold text-6xl md:text-8xl tracking-tighter block mb-6"
          >
            Desde 1977
          </span>

          <h1
            class="text-[var(--color-primary-dark)] text-3xl font-bold mb-8 tracking-tight"
          >
            Nuestra historia comenzó con un saco de granos y un sueño
            compartido.
          </h1>

          <!-- Ajustamos opacidad del texto para que sea legible pero elegante -->
          <div
            class="space-y-6 text-[var(--color-primary-dark)]/70 text-lg leading-relaxed"
          >
            <p>
              Café Artesano nació en el corazón de la ciudad hace más de cuatro
              décadas. Lo que empezó como un pequeño tostadero familiar se ha
              convertido en un punto de encuentro para aquellos que buscan algo
              más que una simple bebida.
            </p>
            <p>
              Nuestra misión es clara: democratizar el café de especialidad.
              Buscamos que cada taza servida sea un puente entre el caficultor y
              tú, respetando los procesos naturales y resaltando la identidad
              única de cada origen.
            </p>
            <p>
              Hoy, seguimos manteniendo la misma esencia que en 1977, pero con
              la precisión técnica que el café moderno exige.
            </p>
          </div>

          <div class="mt-12">
            <!-- Asumo que tu botón variant="primary" ahora destaca sobre blanco -->
            <Button
              text="Reserva tu mesa"
              variant="primary"
              onclick="window.location.href='/contacto'"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Galería de Productos -->
    <section class="px-6 py-24 max-w-7xl mx-auto">
      <div class="mb-12">
        <h2
          class="text-[var(--color-primary)] font-bold uppercase text-xs tracking-[0.4em] mb-4"
        >
          Nuestra Selección
        </h2>
        <h3
          class="text-[var(--color-primary-dark)] text-3xl font-bold tracking-tight"
        >
          Bebidas y sabores que inspiran.
        </h3>
      </div>

      <!-- Pasamos las imágenes ya importadas al PhotoGrid -->
      <PhotoGrid images={gallery} />
    </section>
  </main>
</Layout>
