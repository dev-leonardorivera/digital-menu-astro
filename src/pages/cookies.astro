---
import Layout from "../layouts/Layout.astro";

import { Icon } from "astro-icon/components";
---

<Layout>
  <div class="bg-[var(--color-primary-dark)] min-h-screen">
    <section class="pt-32 pb-20 px-4 max-w-3xl mx-auto">
      <!-- Cabecera Informativa -->
      <div class="mb-12 border-b border-white/10 pb-8 text-left">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-px bg-[var(--color-primary-light)]"></div>
          <span
            class="text-[var(--color-accent)] uppercase text-[10px] tracking-[0.3em] font-bold"
            >Transparencia</span
          >
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tighter">
          Uso de <span class="text-[var(--color-primary-light)]">Cookies</span>
        </h1>
        <p class="text-[var(--color-surface)]/50 text-xs mt-4 italic">
          Queremos que tu navegación sea tan fluida como nuestro café recién
          hecho.
        </p>
      </div>

      <!-- Bloque de Contenido para el Cliente -->
      <div
        class="space-y-10 text-[var(--color-surface)]/80 leading-relaxed text-sm font-light"
      >
        <section>
          <h2 class="text-white font-bold text-lg mb-4 flex items-center gap-2">
            ¿Qué son las cookies?
          </h2>
          <p>
            Son pequeños archivos de texto que se guardan en tu dispositivo
            (ordenador o móvil) cuando nos visitas. Nos sirven para recordar tus
            preferencias, saber si ya has venido antes y mejorar el
            funcionamiento de la web.
          </p>
        </section>

        <section>
          <h2 class="text-white font-bold text-lg mb-4">
            ¿Cuáles utilizamos en esta web?
          </h2>
          <div class="grid gap-4">
            <!-- Cookies Técnicas -->
            <div class="bg-white/5 border border-white/10 p-5 rounded-2xl">
              <h3
                class="text-[var(--color-primary-light)] font-bold mb-2 uppercase text-xs tracking-widest"
              >
                Necesarias
              </h3>
              <p class="text-xs">
                Permiten que la web cargue rápido y se vea bien. Sin ellas, la
                página no funcionaría correctamente. Estas siempre están
                activas.
              </p>
            </div>

            <!-- Cookies de Análisis -->
            <div class="bg-white/5 border border-white/10 p-5 rounded-2xl">
              <h3
                class="text-[var(--color-primary-light)] font-bold mb-2 uppercase text-xs tracking-widest"
              >
                De Análisis (Google Analytics)
              </h3>
              <p class="text-xs">
                Nos ayudan a entender qué partes de nuestra carta de cafés te
                interesan más o desde qué ciudad nos visitas. Esta información
                es anónima y solo sirve para mejorar nuestro servicio.
              </p>
            </div>

            <!-- Cookies de Terceros -->
            <div class="bg-white/5 border border-white/10 p-5 rounded-2xl">
              <h3
                class="text-[var(--color-primary-light)] font-bold mb-2 uppercase text-xs tracking-widest"
              >
                De Terceros (Redes Sociales y Mapas)
              </h3>
              <p class="text-xs">
                Si interactúas con nuestro mapa de ubicación o enlaces de
                Instagram, estos servicios pueden instalar cookies propias para
                mostrarte contenido personalizado.
              </p>
            </div>
          </div>
        </section>
      </div>

      <!-- Botón volver con icono de retorno -->
      <div class="mt-16">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-[var(--color-primary-light)] hover:text-white transition-colors text-xs font-bold uppercase tracking-widest group"
        >
          <Icon
            name="send"
            class="w-4 h-4 rotate-180 transition-transform group-hover:-translate-x-1"
          />
          Regresar a la carta
        </a>
      </div>
    </section>
  </div>
</Layout>
